# === APP CONFIG ===
APP_NAME=Pai&MaeIntegrado
APP_ENV=development
APP_TIMEZONE=America/Recife
DEBUG=True

# === DATABASE (Supabase) ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
DATABASE_URL=postgresql://user:password@db.supabase.co:5432/postgres

# === JWT ===
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# === CORS & SECURITY ===
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.vercel.app

# === GOOGLE AI ===
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_VISION_API_KEY=your-google-vision-key-here

# === EMAIL (SMTP) ===
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here

# === SCHEDULER ===
SCHEDULER_ENABLED=True

# === FIREBASE (Push Notifications) ===
FIREBASE_PROJECT_ID=your-firebase-project
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-email

# === GITHUB (CI/CD) ===
GITHUB_TOKEN=your-github-token
GITHUB_REPOSITORY=your-username/repo-name

# === DEPLOYMENT ===
# Railway
RAILWAY_ENVIRONMENT_ID=production
RAILWAY_API_TOKEN=your-railway-token

# Vercel
VERCEL_TOKEN=your-vercel-token
VERCEL_PROJECT_ID=your-vercel-project-id
VERCEL_TEAM_ID=your-vercel-team-id
